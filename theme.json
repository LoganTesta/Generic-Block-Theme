{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "templateParts": [
        {
            "name": "header",
            "area": "header",
            "title": "Header"
        },
        {
            "name": "footer",
            "area": "footer",
            "title": "Footer"
        }
    ],
    "patterns": [
        "hero-banner-with-overlap-images",
        "short-text-surrounded-by-round-images",
        "mixed-shape-gallery"
    ],
    "customTemplates": [
        {
            "name": "page-about-us",
            "title": "About us page",
            "postTypes": [ "page", "post" ]
        }
    ],
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "primary",
                    "color": "#116020",
                    "name": "Main Palette"
                },
                {
                    "slug": "secondary",
                    "color": "#22aa60",
                    "name": "Secondary Palette"
                }
            ],
            "gradients": [
                {
                    "slug": "primary-to-secondary",
                    "gradient": "linear-gradient(0deg, var(--wp--preset--color--primary), var(--wp--preset--color--secondary))",
                    "name": "Priamry to Secondary"
                }
            
            ],
            "dutone": [
            
            ]
        },
        "typography": {
            "fontFamilies": [ 
                {
                    "fontFamily": "Arial, sans-serif",
                    "slug": "generic-font-family",
                    "name" : "Generic Font Family"
                },
                {
                    "fontFamily": "Times New Roman, serif",
                    "slug": "times-new-roman-font-family",
                    "name" : "Times New Roman Font Family"
                }
                
            ],
            "fontSizes": [
                {
                    "slug": "extra-small",
                    "size": "10px",
                    "name": "Extra small"
                },
                {
                    "slug": "small",
                    "size": "12px",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "16px",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "20px",
                    "name": "Large"
                },
                {
                    "slug": "extra-large",
                    "size": "24px",
                    "name": "Extra Large"
                }
            ],
            "lineHeight": true
        },
        "layout": {
            "contentSize": "1000px",
            "wideSize": "1600px"
            
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "units": ["px", "em", "rem", "%", "vh", "vw"]
        },
        "border": {
            "width": true,
            "style": true,
            "color": true,
            "radius": true            
        },
        "blocks": {
            "core/heading": {
                "slug": "tertiary",
                "color": "#00cc00",
                "name": "Tertiary"
                
            }
        }
    },
    "custom": {
       "spacing": "10px",
       "extra-spacing": "20px"
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--prset--color--accent-2)"
                }
            }
        },
        "typography": {
            "fontSize": "var(--wp--preset--font-size--medium)",
            "fontFamily": "var(--wp--preset--font-family--system-fonts)",
            "lineHeight": "1.7"
        }
        
    
    },
    "custom-templates": [],
    "templateParts": [] 
}
